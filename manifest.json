{
  "id": "babelforge.laravel-module",
  "name": "Laravel Module",
  "version": "1.0.2",
  "requirements": {
    "php": ">=8.4"
  },
  "description": "A Laravel-based BabelChrome web module used to validate framework-agnostic module execution.",
  "type": "tool",
  "enabled": true,
  "runtime": {
    "type": "process-web",
    "command": "php",
    "args": [
      "-S",
      "127.0.0.1:{{ port }}",
      "-t",
      "public",
      "public/index.php"
    ],
    "cwd": ".",
    "readyUrl": "http://127.0.0.1:{{ port }}/health",
    "timeoutMs": 10000,
    "stop": {
      "signal": "TERM",
      "timeoutMs": 3000
    }
  },
  "readiness": {
    "type": "command",
    "command": "php bin/readiness.php",
    "timeoutMs": 3000
  },
  "routes": [
    {
      "scheme": "babelchrome",
      "host": "laravel",
      "handler": "index"
    }
  ],
  "fileTypes": [],
  "hooks": [
    "settings.section.register"
  ],
  "permissions": [
    "serve-assets"
  ],
  "menuItems": [
    {
      "id": "laravel.open",
      "label": "Open Laravel Module",
      "hook": "settings.section.register",
      "route": "babelchrome://laravel",
      "contexts": [
        "settings.modules"
      ]
    }
  ],
  "badge": {
    "text": "LARA",
    "textColor": "#ffffff",
    "backgroundColor": "#ff2d20"
  },
  "settings": {
    "route": "babelchrome://modules"
  }
}
