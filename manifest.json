{
  "id": "babelforge.laravel-module",
  "name": "Laravel Module",
  "version": "1.0.3",
  "requirements": {
    "php": ">=8.4"
  },
  "requiredSettings": {
    "phpPath": {
      "type": "executable",
      "label": "PHP executable",
      "binary": "php",
      "minVersion": "8.4",
      "autoDetectPaths": [
        "/opt/homebrew/opt/php@8.4/bin/php",
        "/opt/homebrew/opt/php/bin/php",
        "/opt/homebrew/bin/php",
        "/usr/local/opt/php@8.4/bin/php",
        "/usr/local/opt/php/bin/php",
        "/usr/local/bin/php",
        "/opt/local/bin/php",
        "/usr/bin/php"
      ],
      "versionArgs": [
        "-v"
      ]
    }
  },
  "description": "A Laravel-based BabelChrome web module used to validate framework-agnostic module execution.",
  "type": "tool",
  "enabled": true,
  "runtime": {
    "type": "process-web",
    "command": "{{ settings.phpPath }}",
    "args": [
      "-S",
      "127.0.0.1:{{ port }}",
      "-t",
      "public",
      "public/index.php"
    ],
    "cwd": ".",
    "readyUrl": "http://127.0.0.1:{{ port }}/health",
    "timeoutMs": 10000,
    "stop": {
      "signal": "TERM",
      "timeoutMs": 3000
    }
  },
  "routes": [
    {
      "scheme": "babelchrome",
      "host": "laravel",
      "handler": "index"
    }
  ],
  "fileTypes": [],
  "hooks": [
    "settings.section.register"
  ],
  "permissions": [
    "serve-assets"
  ],
  "menuItems": [
    {
      "id": "laravel.open",
      "label": "Open Laravel Module",
      "hook": "settings.section.register",
      "route": "babelchrome://laravel",
      "contexts": [
        "settings.modules"
      ]
    }
  ],
  "badge": {
    "text": "LARA",
    "textColor": "#ffffff",
    "backgroundColor": "#ff2d20"
  },
  "settings": {
    "route": "babelchrome://modules"
  }
}
